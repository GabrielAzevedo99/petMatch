{
  "openapi": "3.0.3",
  "info": {
    "title": "PetMatch Animal API",
    "version": "1.0.0",
    "description": "Contrato das informações de animais para telas de início, detalhes e match."
  },
  "paths": {
    "/animals": {
      "get": {
        "summary": "Lista todos os animais disponíveis",
        "responses": {
          "200": {
            "description": "Lista de animais",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Animal"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/animals/{id}": {
      "get": {
        "summary": "Retorna os detalhes de um animal",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalhes do animal",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Animal"
                }
              }
            }
          },
          "404": {
            "description": "Animal não encontrado"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Animal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "animal-001"
          },
          "name": {
            "type": "string",
            "example": "Luna"
          },
          "category": {
            "type": "string",
            "enum": [
              "Cão",
              "Gato",
              "Silvestre"
            ]
          },
          "species": {
            "type": "string",
            "example": "SRD"
          },
          "breed": {
            "type": "string",
            "example": "SRD"
          },
          "age": {
            "type": "string",
            "example": "1 ano"
          },
          "sex": {
            "type": "string",
            "enum": [
              "Macho",
              "Fêmea"
            ]
          },
          "size": {
            "type": "string",
            "enum": [
              "Pequeno",
              "Médio",
              "Grande"
            ]
          },
          "matchScore": {
            "type": "integer",
            "format": "int32",
            "example": 92
          },
          "isFavorite": {
            "type": "boolean",
            "example": false
          },
          "badges": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "environment": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "behaviors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "compatibilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "health": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string",
            "example": "Luna é uma gata pequena e carinhosa, ideal para apartamento."
          },
          "story": {
            "type": "string",
            "example": "Encontrada em um parque, Luna chegou até nós com muita fome e agora procura um lar tranquilo."
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "contact": {
            "$ref": "#/components/schemas/Contact"
          }
        },
        "required": [
          "id",
          "name",
          "category",
          "species",
          "breed",
          "age",
          "sex",
          "size",
          "matchScore",
          "environment",
          "behaviors",
          "compatibilities",
          "contact"
        ]
      },
      "Contact": {
        "type": "object",
        "properties": {
          "caretakerName": {
            "type": "string",
            "example": "Karen Lima"
          },
          "phone": {
            "type": "string",
            "example": "(11) 91234-5678"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "karen.lima@petmatch.org"
          }
        },
        "required": [
          "caretakerName",
          "phone",
          "email"
        ]
      }
    }
  }
}
